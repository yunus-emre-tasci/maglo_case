    "/users/register": {
      "post": {
        "summary": "Register new user",
        "responses": {
          "200": {
            "example": {
              "success": true,
              "message": "User registered successfully.",
              "data": {
                "id": "60d0fe4f5311236168a109ca",
                "fullName": "John Doe",
                "email": "user@example.com"
              }
            }
          }
        }
      }
    },
    "/users/login": {
      "post": {
        "summary": "Authenticate user",
        "responses": {
          "200": {
            "example": {
              "success": true,
              "message": "Login successful.",
              "data": {
                "user": {
                  "id": "60d0fe4f5311236168a109ca",
                  "fullName": "John Doe",
                  "email": "user@example.com"
                },
                "accessToken": "eyJh..."
              }
            }
          },
          "400": {
            "example": {
              "success": false,
              "message": "Email and password are required."
            }
          },
          "401": {
            "example": {
              "success": false,
              "message": "Invalid email or password."
            }
          },
          "403": {
            "example": {
              "success": false,
              "message": "Your account has been deactivated."
            }
          },
          "429": {
            "example": {
              "success": false,
              "message": "Too many authentication attempts..."
            }
          }
        }
      }
    },
    "/users/logout": {
      "post": { "summary": "Log out the user" }
    },
    "/users/refresh-token": {
      "post": {
        "summary": "Refresh access token",
        "responses": {
          "200": { "example": { "accessToken": "string" } }
        }
      }
    },
    "/users/profile": {
      "get": {
        "summary": "Get current user profile",
        "responses": {
          "200": {
            "example": {
              "id": "60d0fe4f5311236168a109ca",
              "fullName": "John Doe",
              "email": "user@example.com",
              "role": "user",
              "isActive": true
            }
          }
        }
      }
    }
  }
